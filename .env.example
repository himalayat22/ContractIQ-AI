# =============================================================================
# ContractIQ AI — Root environment template (MVP)
# Copy to .env and adjust per environment. Do not commit .env.
# See docs/SYSTEM_DESIGN.md §0 (MVP Architecture)
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# Application URLs (CORS, emails, presigned redirects)
# -----------------------------------------------------------------------------
WEB_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000/api/v1

# -----------------------------------------------------------------------------
# Service ports (local)
# -----------------------------------------------------------------------------
API_GATEWAY_PORT=4000
IDENTITY_SERVICE_PORT=4001
CONTRACT_SERVICE_PORT=4002
AI_SERVICE_PORT=4003
NOTIFICATION_SERVICE_PORT=4004

# -----------------------------------------------------------------------------
# Internal service URLs (gateway proxy & service-to-service)
# -----------------------------------------------------------------------------
IDENTITY_SERVICE_URL=http://localhost:4001
CONTRACT_SERVICE_URL=http://localhost:4002
AI_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4004

# Shared secret for internal routes (MVP: X-Internal-Api-Key header)
INTERNAL_API_KEY=change-me-use-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Auth (MVP: HS256 JWT)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# MongoDB (single cluster; logical DB per service — SYSTEM_DESIGN §0.6)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_IDENTITY=contractiq_identity
MONGODB_DB_CONTRACT=contractiq_contract
MONGODB_DB_AI=contractiq_ai
MONGODB_DB_AUDIT=contractiq_audit
MONGODB_DB_NOTIFICATION=contractiq_notification

# -----------------------------------------------------------------------------
# Redis (BullMQ queues + rate limiting + idempotency)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# BullMQ queue names (MVP — SYSTEM_DESIGN §0.8)
BULL_QUEUE_INGESTION_EXTRACT=ingestion.extract
BULL_QUEUE_AI_ANALYZE=ai.analyze
BULL_QUEUE_ANALYSIS_COMPLETE=analysis.complete
BULL_QUEUE_NOTIFICATION_SEND=notification.send

# -----------------------------------------------------------------------------
# Object storage (MinIO local / AWS S3 production)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=contractiq-contracts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRES_SECONDS=3600
CONTRACT_MAX_FILE_SIZE_BYTES=52428800

# -----------------------------------------------------------------------------
# AI / LLM (ai-service — Google Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=120000
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_MS=1000
GEMINI_MAX_CONTRACT_CHARS=120000

# Legacy / future (not used by ai-service MVP)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AI_RATE_LIMIT_PER_TENANT_PER_MINUTE=30

# -----------------------------------------------------------------------------
# Email (notification-service)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@contractiq.local
EMAIL_FROM_NAME=ContractIQ AI

# -----------------------------------------------------------------------------
# Rate limiting (api-gateway)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Docker Compose (infrastructure/docker/docker-compose.yml)
# Inside containers use: mongodb://mongodb:27017, redis://redis:6379
# On host use published ports: localhost:27017, localhost:6379
# -----------------------------------------------------------------------------
# CONTRACT_UPLOAD_DIR=/app/apps/contract-service/uploads
