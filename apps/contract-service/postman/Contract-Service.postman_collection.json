{
  "info": {
    "_postman_id": "contractiq-contract-service-mvp",
    "name": "ContractIQ — Contract Service",
    "description": "MVP contract APIs (port 4002). Set `baseUrl`, `tenantId`, and `createdBy` collection variables before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4002/api/v1" },
    { "key": "tenantId", "value": "674a1b2c3d4e5f6789012346" },
    { "key": "createdBy", "value": "674a1b2c3d4e5f6789012345" },
    { "key": "contractId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ready"
          }
        }
      ]
    },
    {
      "name": "Contracts",
      "item": [
        {
          "name": "POST /contracts/upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
                  "pm.test('contract id present', () => pm.expect(json.data.id).to.be.a('string'));",
                  "if (json.data?.id) pm.collectionVariables.set('contractId', json.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Request-ID", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "sample-contract.pdf" },
                { "key": "title", "value": "Vendor MSA - Acme Corp", "type": "text" },
                { "key": "counterparty", "value": "Acme Corp", "type": "text" },
                { "key": "contractType", "value": "msa", "type": "text" },
                { "key": "effectiveDate", "value": "2026-01-15", "type": "text" },
                { "key": "tags", "value": "vendor,2026", "type": "text" },
                { "key": "tenantId", "value": "{{tenantId}}", "type": "text" },
                { "key": "createdBy", "value": "{{createdBy}}", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/contracts/upload"
          }
        },
        {
          "name": "GET /contracts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
                  "pm.test('data is array', () => pm.expect(json.data).to.be.an('array'));",
                  "pm.test('pagination present', () => pm.expect(json.pagination).to.be.an('object');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Request-ID", "value": "{{$guid}}" }],
            "url": {
              "raw": "{{baseUrl}}/contracts?page=1&limit=20&status=uploading",
              "host": ["{{baseUrl}}"],
              "path": ["contracts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "uploading" },
                { "key": "contractType", "value": "msa", "disabled": true },
                { "key": "q", "value": "Acme", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /contracts/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.eql(true));",
                  "pm.test('id matches', () => pm.expect(json.data.id).to.eql(pm.collectionVariables.get('contractId')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Request-ID", "value": "{{$guid}}" }],
            "url": "{{baseUrl}}/contracts/{{contractId}}"
          }
        },
        {
          "name": "DELETE /contracts/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-Request-ID", "value": "{{$guid}}" }],
            "url": "{{baseUrl}}/contracts/{{contractId}}"
          }
        },
        {
          "name": "GET /contracts/:id (not found)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('CONTRACT_NOT_FOUND', () => pm.expect(pm.response.json().error.code).to.eql('CONTRACT_NOT_FOUND'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/contracts/674a1b2c3d4e5f6789012399"
          }
        }
      ]
    }
  ]
}
