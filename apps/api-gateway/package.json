{
  "name": "@contractiq/api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "ContractIQ API gateway — routing, JWT verification, identity proxy (MVP)",
  "type": "module",
  "main": "./src/app.js",
  "scripts": {
    "dev": "node --watch --env-file=../../.env src/app.js",
    "build": "node --check src/app.js",
    "start": "node --env-file=../../.env src/app.js",
    "lint": "eslint src --max-warnings 0",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "rimraf": "^6.0.1"
  }
}
